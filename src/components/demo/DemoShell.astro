---
type Props = {
  title: string;
  description?: string;
};

const { title, description } = Astro.props;
---

<div class="wrap">
  <header class="hero">
    <h1>{title}</h1>
    {description ? <p set:html={description} /> : null}
  </header>

  <slot />
</div>

<style>
  .hero {
    margin-bottom: 14px;
  }
</style>
