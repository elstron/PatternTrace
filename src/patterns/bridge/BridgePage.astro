---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoShell from '../../components/demo/DemoShell.astro';
import DemoGrid from '../../components/demo/DemoGrid.astro';
import CodeExamplePanel from '../_shared/components/CodeExamplePanel.astro';

import BridgeDescription from './components/BridgeDescription.astro';
import BridgeDiagram from './components/BridgeDiagram.astro';
import BridgeDemo from './components/BridgeDemo.astro';

import { meta } from './meta';
import { bridgeExample } from './code-examples.js';
---

<BaseLayout title={meta.pageTitle}>
  <DemoShell title={meta.title}>
    <BridgeDescription />

    <BridgeDiagram />

    <DemoGrid>
      <BridgeDemo />
      <CodeExamplePanel
        title={bridgeExample.title}
        subtitle={bridgeExample.subtitle}
        note={bridgeExample.note}
        ts={bridgeExample.ts}
        js={bridgeExample.js}
      />
    </DemoGrid>

    <script>
      import './bridge-logic.js';
    </script>
  </DemoShell>
</BaseLayout>
