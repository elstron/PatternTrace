---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoShell from '../../components/demo/DemoShell.astro';
import DemoGrid from '../../components/demo/DemoGrid.astro';
import CodeExamplePanel from '../_shared/components/CodeExamplePanel.astro';

import FactoryDescription from './components/FactoryDescription.astro';
import FactoryDiagram from './components/FactoryDiagram.astro';
import FactoryDemo from './components/FactoryDemo.astro';

import { meta } from './meta';
import { factoryExample } from './code-examples.js';
---

<BaseLayout title={meta.pageTitle}>
  <DemoShell title={meta.title}>
    <FactoryDescription />

    <FactoryDiagram />

    <DemoGrid>
      <FactoryDemo />
      <CodeExamplePanel
        title={factoryExample.title}
        subtitle={factoryExample.subtitle}
        note={factoryExample.note}
        ts={factoryExample.ts}
        js={factoryExample.js}
      />
    </DemoGrid>

    <script>
      import './factory-logic.js';
    </script>
  </DemoShell>
</BaseLayout>
