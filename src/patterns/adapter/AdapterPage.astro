---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoShell from '../../components/demo/DemoShell.astro';
import DemoGrid from '../../components/demo/DemoGrid.astro';
import CodeExamplePanel from '../_shared/components/CodeExamplePanel.astro';

import AdapterDescription from './components/AdapterDescription.astro';
import AdapterDiagram from './components/AdapterDiagram.astro';
import AdapterDemo from './components/AdapterDemo.astro';

import { meta } from './meta';
import { adapterExample } from './code-examples.js';
---

<BaseLayout title={meta.pageTitle}>
  <DemoShell title={meta.title}>
    <AdapterDescription />

    <AdapterDiagram />

    <DemoGrid>
      <AdapterDemo />
      <CodeExamplePanel
        title={adapterExample.title}
        subtitle={adapterExample.subtitle}
        note={adapterExample.note}
        ts={adapterExample.ts}
        js={adapterExample.js}
      />
    </DemoGrid>

    <script>
      import './adapter-logic.js';
    </script>
  </DemoShell>
</BaseLayout>
