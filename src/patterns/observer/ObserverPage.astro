---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoShell from '../../components/demo/DemoShell.astro';
import DemoGrid from '../../components/demo/DemoGrid.astro';
import CodeExamplePanel from '../_shared/components/CodeExamplePanel.astro';

import DiagramSection from './components/DiagramSection.astro';
import SubjectSection from './components/SubjectSection.astro';
import ObserversSection from './components/ObserversSection.astro';
import ObserverDescription from './components/ObserverDescription.astro';

import { meta } from './meta';
import { observerExample } from './code-examples.js';
---

<BaseLayout title={meta.pageTitle}>
  <DemoShell title={meta.title}>
    <ObserverDescription />

    <DiagramSection />

    <DemoGrid>
      <SubjectSection />
      <ObserversSection />
    </DemoGrid>

    <CodeExamplePanel
      title={observerExample.title}
      subtitle={observerExample.subtitle}
      note={observerExample.note}
      ts={observerExample.ts}
      js={observerExample.js}
    />
    <script>
      import './observer-logic.js';
    </script>
  </DemoShell>
</BaseLayout>
